# 基本方針：全て ignore し、管理対象だけを明示的に許可する
# （ツールが書き込む state・秘匿ファイルの誤コミット防止）
*

# 管理対象の許可リスト
!nvim/
!nvim/**
!alacritty.toml
!starship.toml
!tmux/
!tmux/**
!ccstatusline/
!ccstatusline/*
!herdr/
!herdr/config.toml
!zsh/
!zsh/**
!mise/
!mise/config.toml
!ideavim/
!ideavim/**
!claude/
!claude/**
!codex/
!codex/**
!lazygit/
!lazygit/config.yml
!git/
!git/ignore
!worktrunk/
!worktrunk/config.toml
!gh/
!gh/config.yml
!.gitignore

# 許可したディレクトリ配下でも ignore するもの（後勝ちで上の ! を打ち消す）
.DS_Store
._*
[._]*.sw[a-p]
[._]*.un~
*~
Session.vim
.netrwhist
tags
__pycache__/
*.pyc
