#!/bin/bash

# プロジェクトルートを取得
PROJECT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")
LEARNINGS_FILE="$PROJECT_ROOT/.claude/learnings.md"

# .claude ディレクトリが存在しない場合は作成
if [ ! -d "$PROJECT_ROOT/.claude" ]; then
    mkdir -p "$PROJECT_ROOT/.claude"
fi

# learnings.md が存在しない場合は作成
if [ ! -f "$LEARNINGS_FILE" ]; then
    cat > "$LEARNINGS_FILE" << 'EOF'
# プロジェクト固有の学び

このファイルは開発中の学びを蓄積します。

## カテゴリ例

- **実装パターン**: プロジェクト固有のコーディングパターン
- **DI設定**: 依存性注入の設定方法
- **エラー対処**: よくあるエラーとその解決方法
- **テスト**: テスト実装のポイント
- **API**: API設計・実装の注意点
- **DB**: データベース関連の学び
- **環境設定**: 開発環境の設定

---

EOF
fi

# 引数がない場合はヘルプを表示
if [ $# -eq 0 ]; then
    echo "使い方:"
    echo "  learn \"[カテゴリ] 内容\""
    echo ""
    echo "例:"
    echo "  learn \"[DI設定] 新しいRepositoryを追加したらrepository.goのProvideSetに追加が必要\""
    echo "  learn \"[エラー対処] user_idはstring型だがAPIではnumberで返される\""
    echo ""
    echo "現在の学びファイル: $LEARNINGS_FILE"
    exit 0
fi

# 学びを記録
LEARNING="$*"
echo "- $LEARNING ($(date +%Y-%m-%d))" >> "$LEARNINGS_FILE"
echo "✅ 記録しました: $LEARNING"
echo "📄 ファイル: $LEARNINGS_FILE"
